{
  "manifest_version": 3,
  "name": "Udemy Transcription Helper",
  "version": "1.0",
  "description": "Copie et résume les transcriptions Udemy avec Gemini AI",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://www.udemy.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.udemy.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Udemy Transcription Helper"
  },
  "background": {
    "service_worker": "background.js"
  }
}
